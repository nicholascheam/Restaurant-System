<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.restaurantsystem.OptionController"
      prefWidth="320" prefHeight="420"
      style="-fx-padding:20;">

    <Label fx:id="titleLabel"
           text="Customize Item"
           style="-fx-font-size:18px; -fx-font-weight:bold;" />

    <VBox fx:id="optionsBox" spacing="10" />

    <Label text="Notes:" />
    <TextField fx:id="notesField"
               promptText="e.g. no onion" />

    <Label text="Quantity:" />
    <Spinner fx:id="qtySpinner" />

    <Label fx:id="totalLabel"
           text="Total: $0.00"
           style="-fx-font-size:16px; -fx-font-weight:bold;" />

    <HBox spacing="15" alignment="CENTER">
        <Button text="Cancel" onAction="#handleCancel" />
        <Button text="Add To Cart" onAction="#handleAdd" />
    </HBox>

</VBox>