<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.restaurantsystem.OptionAdminController">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="topbar">
            <Label text="Manage Item Options"
                   style="-fx-font-size:18px; -fx-font-weight:bold;" />
            <Button text="Back" onAction="#goBack"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="table">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                <TableColumn fx:id="nameCol" text="Option Name" prefWidth="140"/>
                <TableColumn fx:id="valuesCol" text="Values" prefWidth="220"/>
                <TableColumn fx:id="typeCol" text="Type" prefWidth="100"/>
                <TableColumn fx:id="requiredCol" text="Required" prefWidth="90"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" styleClass="form-panel">
            <Label fx:id="itemLabel" text="Selected Item"/>
            <TextField fx:id="nameField" promptText="Option Name"/>
            <TextField fx:id="valuesField" promptText="Values (A,B,C)"/>
            <ComboBox fx:id="typeBox"/>
            <CheckBox fx:id="requiredBox" text="Required"/>
            <HBox spacing="10">
                <Button text="Add" onAction="#handleAdd"/>
                <Button text="Update" onAction="#handleUpdate"/>
                <Button text="Delete" onAction="#handleDelete"/>
            </HBox>
            <Label fx:id="statusLabel"/>
        </VBox>
    </right>

</BorderPane>